# BGD Project — Environment Configuration (template)
# Copy this to .env and adjust values.

# Number of CSV files to process (default: 3). Set to 0 or "all" for full dataset.
ETL_DATA_SAMPLE_SIZE=3

# PostgreSQL password — avoid shell-special characters ($, ", ', \, `).
POSTGRES_PASSWORD=ChangeMe123

# Kafka — change the external port if 29092 is already taken on your machine.
# Keep both values in sync (scripts connect via KAFKA_BOOTSTRAP_SERVERS).
KAFKA_EXTERNAL_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
